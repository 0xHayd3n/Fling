{
  "name": "fling-monorepo",
  "version": "0.5.0",
  "description": "Fling — MCP server + desktop GUI for deploying Android apps.",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build -w @eleutex/fling",
    "test": "npm test -w @eleutex/fling",
    "smoke": "npm run smoke -w @eleutex/fling",
    "clean": "npm run clean -w @eleutex/fling"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "author": "Hayden Seymour <contact@haydenseymour.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eleutex/fling.git"
  },
  "bugs": {
    "url": "https://github.com/eleutex/fling/issues"
  },
  "homepage": "https://github.com/eleutex/fling#readme"
}
