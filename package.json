{
  "name": "fling-monorepo",
  "version": "0.7.0",
  "description": "Fling — MCP server + desktop GUI for deploying Android apps.",
  "private": true,
  "type": "module",
  "scripts": {
    "setup": "npm install && npm install --prefix packages/mcp-server && npm install --prefix apps/desktop --install-links",
    "sync:desktop": "npm install --prefix apps/desktop --install-links",
    "build": "npm run build --prefix packages/mcp-server",
    "test": "npm test --prefix packages/mcp-server && npm test --prefix apps/desktop",
    "test:mcp": "npm test --prefix packages/mcp-server",
    "test:desktop": "npm test --prefix apps/desktop",
    "lint:desktop": "npm run lint --prefix apps/desktop",
    "smoke": "npm run smoke --prefix packages/mcp-server",
    "clean": "npm run clean --prefix packages/mcp-server"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "author": "Hayden Seymour <contact@haydenseymour.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0xHayd3n/Fling.git"
  },
  "bugs": {
    "url": "https://github.com/0xHayd3n/Fling/issues"
  },
  "homepage": "https://github.com/0xHayd3n/Fling#readme"
}
